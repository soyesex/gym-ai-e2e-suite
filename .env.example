# URL de tu instancia local de Supabase (Docker)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Anon key de Supabase local (la saca `supabase status`)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SOLO para fixtures que necesitan bypass de RLS
SUPABASE_SERVICE_ROLE_KEY=

# Path al repo de la app (default: ../gym-ai)
GYM_AI_PATH=../gym-ai